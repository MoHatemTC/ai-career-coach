# === Database ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=career_coach
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# === CORS ===
CORS_ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:8000"]'

# === LiteLLM (shared) ===
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=your_litellm_key
LLM_MODEL=azure/FW-Kimi-K2.6
# Embeddings run locally (BAAI/bge-base-en-v1.5, 768-dim) — configured in
# app/core/embeddings.py, no env vars needed.

# === Application Settings ===
PROJECT_NAME="Career Coach"
# The minimum LLM match score (0-100) required to send a job notification to a user.
MATCH_SCORE_NOTIFICATION_THRESHOLD=70
# The maximum number of jobs to notify a single user about per daily search run.
TOP_N_JOBS_PER_USER=3

# === Langfuse Observability ===
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === Test Database ===
# Note: When running tests via `docker compose exec api ...`, docker-compose.yml 
# automatically overrides TEST_POSTGRES_HOST/PORT to point at the 'db' service, 
# and reuses POSTGRES_USER/PASSWORD. The four host/auth values below only matter
# if you are running pytest directly on your host machine.
TEST_POSTGRES_HOST=localhost
TEST_POSTGRES_PORT=5432
TEST_POSTGRES_DB=career_coach_test
TEST_POSTGRES_USER=postgres
TEST_POSTGRES_PASSWORD=your_test_password

# === Test LiteLLM (integration tests only) ===
# Only needed to run `pytest -m integration` against a live proxy. Leave unset
# and the integration tests skip themselves.
TEST_LITELLM_BASE_URL=http://localhost:4000
TEST_LITELLM_API_KEY=your_litellm_key
TEST_LLM_MODEL=azure/FW-Kimi-K2.6